# GRBL Proxy configuration
# Copy to ~/.grbl-proxy/config.yaml and edit as needed.

serial:
  port: auto              # auto-detect, or explicit path e.g. /dev/ttyUSB0
  baud: 115200
  dtr: false              # CRITICAL: false prevents ESP32-S2 reset on connect
  reconnect_interval: 5   # seconds between reconnection attempts

tcp:
  host: 0.0.0.0
  port: 23              # lightburn doesn't seem to allow to change the port 23 is required

web:
  host: 0.0.0.0
  port: 8080

job:
  storage_dir: ~/.grbl-proxy/jobs
  max_history: 20
  start_marker: "G4 P0.0"   # put this in LightBurn's Start G-code device profile field
  end_marker: ""             # leave blank — LightBurn sends M30 to end the job
  auto_detect:
    enabled: false    # disabled: framing/jogging bursts trigger false positives

machine:
  name: "Falcon 2 Pro"
  work_area: [400, 415]   # mm
  status_poll_hz: 4
